{
  "name": "image-editor",
  "version": "1.0.0",
  "description": "SVG editor - convert PNGs, recolor, split components, replace text",
  "scripts": {
    "build": "npm run build:server && npm run build:client",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --outfile=dist/server.js --packages=external",
    "build:client": "esbuild src/client/app.ts --bundle --outfile=public/bundle.js --format=esm --sourcemap",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "esbuild src/client/app.ts --bundle --outfile=public/bundle.js --format=esm --sourcemap --watch",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "potrace": "^2.1.8",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.12",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
