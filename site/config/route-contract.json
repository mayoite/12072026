{
  "version": 3,
  "status": "live-route-auth-contract",
  "entry": {
    "access": "/access",
    "chooseProduct": "/choose-product",
    "dashboard": "/dashboard"
  },
  "planner": {
    "landing": "/planner",
    "guest": "/planner/guest",
    "help": "/planner/help",
    "canvas": "/planner/canvas",
    "fabricGuest": "/planner/fabric/guest",
    "fabricCanvas": "/planner/fabric/canvas",
    "open3dPilot": "/planner/open3d",
    "dashboardRedirect": "/dashboard",
    "_legacyRedirects": {
      "oando-planner": "/planner",
      "buddy-planner": "/planner/canvas"
    }
  },
  "configurator": {
    "landing": "/buddy-planner",
    "guest": "/buddy-planner/guest",
    "editor": "/buddy-planner/editor",
    "workspaceCompatibility": "/buddy-planner/[...slug]",
    "dashboardRedirect": "/buddy-planner/dashboard",
    "_status": "compatibility-redirects-to-unified-planner",
    "_note": "Legacy buddy routes 301 to /planner/** via Next.js page redirects."
  },
  "protectedPrefixes": [
    "/dashboard",
    "/portal",
    "/admin",
    "/crm",
    "/planner/canvas",
    "/oando-planner/canvas",
    "/oando-planner/shared",
    "/buddy-planner/editor",
    "/buddy-planner/t/"
  ],
  "_phase04_admin_routes": {
    "_status": "phase-04 admin portal svg-editor routes",
    "_auth": "withAuth(['admin']) — Phase 04 widens; pre-Phase 07 route-level reuse `site/lib/api/withAuth.ts`",
    "_persistence": "atomic-rename JSON /api/admin/svg-editor/route.ts → site/block-descriptors/{slug}.json",
    "_canonical": "site/features/planner/admin/svg-editor/puckBlockRegistry.tsx (GS locked; see I-D + registry.tsx; PLAN-FAIL-0403/0417)",
    "_gs": "BP-04/BP-05, design §7/11, anti-copy (DESIGN-BENCHMARK-PROTOCOL.md), I-D module paths, full impl: pages use loader+registry+Puck/Render (no any; static verified)",
    "_impl": "04-ADMIN-01/02 + 05-PORT-01/02 + api + alias + getPuckData full routes 2026-07-04 (TDD tests + RSC + withAuth + loader + atomic + runner + Render)",
    "list": "/admin/svg-editor",
    "editById": "/admin/svg-editor/[id]",
    "createStub": "/admin/svg-editor/new",
    "apiPost": "/api/admin/svg-editor"
  },
  "_phase05_portal_svg_routes": {
    "_status": "phase-05 portal public svg-catalog + Puck.Render",
    "_auth": "public (under protected /portal prefix); read-only",
    "_render": "<Render config from one-line alias reexport of canonical puckBlockRegistry; 1 mount per route (BP-05)",
    "_gs": "BP-05, design §7/9, anti-copy (no donor), I-D (verbatim alias), PLAN-FAIL-0404",
    "index": "/portal/svg-catalog",
    "bySlug": "/portal/svg-catalog/[slug]",
    "alias": "site/app/(site)/portal/svg-catalog/puckBlockRegistry.ts (one-line: export * from admin registry)"
  },
  "_phase07_auth_matrix": {
    "_status": "phase-07 planner guest/member/admin permission matrix",
    "_canonical": "site/features/planner/model/plannerPermissions.ts",
    "_commandRegistry": "site/features/planner/project/lib/commands/plannerAccessContext.ts",
    "_apiAuth": "site/lib/api/withAuth.ts + site/app/api/admin/_lib/server.ts requireAdminSession",
    "_guestAllowedActions": ["view", "select"],
    "_guestBlockedActions": ["persist", "import", "export", "publish", "share"],
    "_guestBlockedCommands": ["save", "export-plan", "import-plan", "open-file", "print"],
    "_descriptor422Codes": ["422.invalid", "422.version_mismatch"],
    "_authApiCodes": ["AUTH_REQUIRED", "INSUFFICIENT_PERMISSIONS"]
  },
  "_phase08_persistence": {
    "_status": "phase-08 versioned JSON-on-disk persistence",
    "_writer": "site/features/planner/admin/svg-editor/persistBlockDescriptor.ts",
    "_loader": "site/features/planner/project/catalog/svg/svgBlockDescriptorLoader.ts",
    "_layout": "{slug}.{n}.json + {slug}.latest.json pointer + legacy {slug}.json mirror",
    "_lock": "O_EXCL {slug}.lock, 30s timeout → 409.lock_busy",
    "_errors": ["422.version_mismatch", "409.hash_mismatch", "409.lock_busy"],
    "_archive": "site/block-descriptors/_archive/ rolling 5 versions",
    "_dualRead": "results/site/phase-08/dual-read/ (disk-only until PLAN-FAIL-0409)",
    "_deferred": "PLAN-FAIL-0409 Supabase block_descriptors table"
  },
  "publicGuestRoutes": [
    "/choose-product?mode=guest",
    "/planner/guest",
    "/oando-planner/guest",
    "/buddy-planner/guest"
  ],
  "plannerGuestCookie": {
    "name": "planner_guest_pass",
    "allowedPaths": [
      "/planner",
      "/planner/guest",
      "/planner/canvas",
      "/oando-planner",
      "/oando-planner/guest",
      "/oando-planner/onboarding",
      "/oando-planner/canvas"
    ],
    "blockedActions": [
      "persist",
      "import",
      "export",
      "publish",
      "share"
    ]
  },
  "redirects": {
    "unauthenticatedProtected": "/access?next=<path>",
    "plannerDashboard": "/dashboard",
    "configuratorDashboard": "/dashboard",
    "configuratorWorkspaceCompatibility": "/buddy-planner/[...slug]",
    "legacyOandoPlanner": "/planner",
    "legacyBuddyPlanner": "/planner/canvas"
  },
  "notes": [
    "Canonical workspace planner lives at /planner/**.",
    "Legacy /oando-planner/** and /buddy-planner/** redirect to unified routes.",
    "Planner guest access: dedicated /planner/guest route plus cookie on allowed paths.",
    "Canvas routes are noindex; landing and help are indexable.",
    "Live workspace routes (/planner/guest, /planner/canvas) use Fabric planner until Open3D Phase 05 is accepted (plannnerplan).",
    "Native Open3D pilot: /planner/open3d (in-progress UI; not default entry).",
    "Fabric mirror routes (/planner/fabric/guest, /planner/fabric/canvas) duplicate live stack for rollback drills."
  ],
  "support": {
    "ivr": "/support-ivr"
  },
  "api": {
    "planner": {
      "aiAdvisor": {
        "path": "/api/planner/ai-advisor",
        "method": "POST"
      }
    },
    "theme": {
      "active": {
        "path": "/api/theme/active",
        "method": "GET"
      }
    }
  }
}
