{
  "name": "oando-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "preinstall": "node scripts/guard-workspace-install.mjs",
    "dev": "pnpm --filter oando-site dev",
    "dev:turbo": "pnpm --filter oando-site dev:turbo",
    "check:layout": "node scripts/check-repo-layout.mjs",
    "check:plans-purity": "node scripts/check-plans-purity.mjs",
    "check:docs-purity": "node scripts/check-docs-purity.mjs",
    "check:failures": "node scripts/check-failures.mjs",
    "check:agents-md": "node scripts/check-agents-md.mjs",
    "check:agents-folder": "node scripts/check-agents-folder.mjs",
    "check:active-docs": "node scripts/check-active-docs.mjs",
    "gate": "pnpm run check:layout && pnpm run check:failures && pnpm run check:agents-md && pnpm run check:agents-folder && pnpm run check:active-docs && pnpm run check:plans-purity && pnpm run check:docs-purity && pnpm --filter oando-site gate",
    "gate:full": "pnpm run check:layout && pnpm --filter oando-site gate:full",
    "p0": "pnpm --filter oando-site p0",
    "p0:unit": "pnpm --filter oando-site p0:unit",
    "p0:g8": "pnpm --filter oando-site p0:g8",
    "p0:svg": "pnpm --filter oando-site p0:svg",
    "p0:admin-svg": "pnpm --filter oando-site p0:admin-svg",
    "test:coverage:admin": "pnpm --filter oando-site test:coverage:admin",
    "test:admin:production-auth": "pnpm --filter oando-site test:admin:production-auth",
    "test:e2e:admin-retire-restore": "pnpm --filter oando-site test:e2e:admin-retire-restore",
    "check:chrome-mcp": "pnpm --filter oando-site check:chrome-mcp",
    "test:e2e:planner-world": "pnpm --filter oando-site test:e2e:planner-world",
    "gate:planner": "pnpm --filter oando-site gate:planner",
    "check-sharp": "node scripts/check-sharp.js",
    "build": "pnpm run check-sharp && pnpm --filter oando-site build && pnpm --filter oando-tech-docs build",
    "start": "pnpm --filter oando-site start",
    "lint": "pnpm --filter oando-site lint",
    "typecheck": "pnpm --filter oando-site typecheck",
    "test": "pnpm --filter oando-site test",
    "docs:check:root-links": "node site/scripts/check-root-markdown-links.mjs",
    "docs:sync:all": "pnpm --filter oando-site docs:sync:all",
    "release:gate": "turbo run release:gate",
    "release:gate:fast": "turbo run release:gate:fast",
    "lint:secrets": "secretlint \"**/*.{cjs,css,csv,html,js,json,jsx,md,mjs,ps1,py,sql,toml,ts,tsx,txt,yaml,yml}\" \".env*\" \".gitattributes\" \".gitignore\" \".npmrc\" \".vercelignore\"",
    "vercel:preview": "vercel --yes",
    "vercel:prod": "pnpm run release:gate && vercel --prod --yes",
    "tech-docs:dev": "pnpm --filter oando-tech-docs dev",
    "tech-docs:generate": "pnpm --filter oando-tech-docs generate",
    "tech-docs:check": "pnpm --filter oando-tech-docs check",
    "tech-docs:typecheck": "pnpm --filter oando-tech-docs typecheck",
    "tech-docs:test": "pnpm --filter oando-tech-docs test",
    "tech-docs:build": "pnpm --filter oando-tech-docs build",
    "tech-docs:gate": "pnpm --filter oando-tech-docs gate",
    "postinstall": "node scripts/cleanup-nested-installs.mjs"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "secretlint": "^13.0.2",
    "turbo": "2.10.5"
  },
  "dependencies": {
    "codex": "^0.2.3"
  }
}
