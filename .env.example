# Copy to repo-root `.env.local` (not committed).
# Loaded by `site/scripts/loadEnvLocal.cjs` (repo root first, then `site/.env.local`).
#
# Validate minimum dev keys:
#   pnpm --filter oando-site exec node scripts/validate-launch-env.mjs
#
# Documented assignable keys below: 34 (plus optional commented keys).
# Legacy typo aliases are NOT listed here — see bottom note; use canonical names only.

# --- Required for local dev (`validate-launch-env.mjs`) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Required for production DB routes / Drizzle ---
PRODUCTS_DATABASE_URL=
SUPABASE_AUTH_DATABASE_URL=

# --- Admin allowlist & API tokens ---
ADMIN_EMAILS=
ADMIN_TOKEN=
CUSTOMER_QUERIES_ADMIN_TOKEN=

# --- E2E / Playwright auth (`site/lib/auth/e2eAuthEnv.ts`) ---
E2E_SUPABASE_ADMIN_EMAIL=
E2E_SUPABASE_ADMIN_PASSWORD=
E2E_SUPABASE_USER_EMAIL=
E2E_SUPABASE_USER_PASSWORD=

# --- Supabase (public site client) ---
# PUBLISHABLE_KEY is optional if NEXT_PUBLIC_SUPABASE_ANON_KEY is set (see required section above).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (admin / auth server — backend API routes) ---
NEXT_ADMIN_SUPABASE_URL=
NEXT_ADMIN_PUBLISHABLE_KEY=
NEXT_ADMIN_SUPABASE_ANON_KEY=
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

# --- AI (OpenRouter primary; OpenAI used by some API routes) ---
OPENROUTER_BASE_URL=
OPENROUTER_API_KEY_PRIMARY=
OPENROUTER_API_KEY_BACKUP=
OPENROUTER_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=

# Optional: Gemini / Google routes (deploy templates only unless you enable those features)
# GOOGLE_API_KEY=

# --- Email ---
EMAIL_FROM=
STAFF_NOTIFY_EMAIL=
RESEND_API_KEY=

# --- Cloudflare account API (management / Workers / general API) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Cloudflare R2 / S3-compatible object storage ---
# Used by `site/lib/env.server.ts`, `site/lib/storage/r2Catalog.ts`, asset + backup scripts.
# ONE logical S3 credential pair (Access Key ID + Secret). Two name sets are aliases:
#   preferred for catalog/R2 scripts → CLOUDFLARE_R2_ACCESS_KEY_ID + CLOUDFLARE_R2_SECRET_ACCESS_KEY
#   generic alias                    → CLOUDFLARE_ACCESS_KEY_ID + CLOUDFLARE_SECRET_ACCESS_KEY
# Set EITHER complete pair (both halves). Do not mix halves across pairs.
# Account API tokens are NOT S3 secrets (they produce Unauthorized on Put/List).
CLOUDFLARE_S3_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Optional aliases of the same S3 pair (used only when R2_* pair is incomplete):
CLOUDFLARE_ACCESS_KEY_ID=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_CATALOG_BUCKET=
# Optional second bucket name when planner thumbs differ from catalog CDN
CLOUDFLARE_R2_BUCKET=

# --- Optional: maintenance & tooling ---
# SITE_MAINTENANCE_MODE=readonly
# PG_DUMP_PATH=

# --- Script index (no extra keys) ---
# db:test, db:apply, supabase:backup → PRODUCTS_DATABASE_URL + SUPABASE_AUTH_DATABASE_URL + Supabase keys above
# backup:supabase:r2 → pg_dump both Supabase DBs → R2 (scheduled via GitHub Actions)
# backup:github-secrets:sync → push backup secrets from .env.local to GitHub Actions
# catalog:snapshot:r2 → catalog JSON → R2 backups/catalog/catalog-latest.json
# assets:cdn:*, assets:r2:* → CLOUDFLARE_ACCOUNT_ID + R2/S3 keys above
# assets:r2:count → CLOUDFLARE_R2_CATALOG_BUCKET (default oando-asset-cdn)
# screenshot:planner → dev server at http://localhost:3000 (no extra env)
# inventory:app-pages, inventory:scripts → no credentials; write under results/

# --- Legacy typo aliases (do NOT add to new .env.local) ---
# Still accepted as a last-resort *intact* pair by r2Catalog only:
#   CLOULD_ACCESS_KEY_ID + CLOULDFLARE_S3_SECRET_ACCESS_KEY
# Other typos (migrate away):
#   CLOULDFLARE_S3_URL → CLOUDFLARE_S3_URL
#   CLOOUDFLARE_SECRET_API_TOKEN / CLOULDFLARE_S3_API_TOKEN → CLOUDFLARE_API_TOKEN
# Never use CLOUDFLARE_SECRET_Authorization as an S3 secret.
