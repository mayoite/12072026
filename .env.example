# Copy to repo-root `.env.local` (not committed). Site loads it via `site/scripts/loadEnvLocal.cjs`.
ADMIN_EMAILS=
ADMIN_TOKEN=
CUSTOMER_QUERIES_ADMIN_TOKEN=
E2E_SUPABASE_ADMIN_EMAIL=
E2E_SUPABASE_ADMIN_PASSWORD=
E2E_SUPABASE_USER_EMAIL=
E2E_SUPABASE_USER_PASSWORD=

# Supabase DATABASE 
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase SERVER (Admin/Auth DB - used by backend API routes)
NEXT_ADMIN_SUPABASE_URL=
NEXT_ADMIN_PUBLISHABLE_KEY=
NEXT_ADMIN_SUPABASE_ANON_KEY=
SUPABASE_ADMIN_SERVICE_ROLE_KEY=

# DATABASE (Supabase Postgres — Drizzle server-only row access)
PRODUCTS_DATABASE_URL=
SUPABASE_AUTH_DATABASE_URL=
# Optional: override pg_dump path on Windows if not on PATH
# PG_DUMP_PATH=

# AI
OPENROUTER_BASE_URL=
OPENROUTER_API_KEY_PRIMARY=
OPENROUTER_API_KEY_BACKUP=
OPENROUTER_MODEL=

# OTHERS
EMAIL_FROM=
STAFF_NOTIFY_EMAIL=

#RESEND
RESEND_API_KEY=
# Optional: read-only maintenance during Supabase outages
# SITE_MAINTENANCE_MODE=readonly

# CLOUDFLARE S3 (assets + SQL/repo backups)
TOKEN_NAME=
CLOUDFLARE_S3_URL=
CLOUDFLARE_SECRET_ACCESS_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCESS_KEY_ID=

# --- Scripts: DB / Supabase / R2 (configure in .env.local, not committed) ---
# db:test, db:apply, supabase:backup → PRODUCTS_DATABASE_URL + SUPABASE_AUTH_DATABASE_URL + Supabase keys above
# backup:supabase:r2 → pg_dump both Supabase DBs → R2 (scheduled via GitHub Actions)
# backup:github-secrets:sync → push backup secrets from .env.local to GitHub Actions
# catalog:snapshot:r2 → catalog JSON → R2 backups/catalog/catalog-latest.json
# SITE_MAINTENANCE_MODE=readonly → banner + block admin/saves (see docs/database/RESTORE-RUNBOOK.md)
# assets:cdn:*, assets:r2:* → CLOUDFLARE_ACCOUNT_ID, CLOUDFLARE_S3_URL, CLOUDFLARE_ACCESS_KEY_ID, CLOUDFLARE_SECRET_ACCESS_KEY
# assets:r2:count → optional CLOUDFLARE_R2_CATALOG_BUCKET (default oando-asset-cdn)
# screenshot:planner → dev server at http://localhost:3000 (no extra env)
# inventory:app-pages, inventory:scripts → no credentials; write under results/
