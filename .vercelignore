# Repo-root deploy ignore list for Vercel CLI uploads.
# The app itself is the single Next.js project in site/.
.git
.vercel
.agents
.codex
.cursor
.claude
.tmp
Documents
archive
node_modules

# Canonical site-level ignores, prefixed for repo-root deploys.
site/node_modules
site/.next
site/coverage
site/reports
site/backup
site/backups
site/chat-logs
site/playwright-report
site/test-results
site/tests
site/__mocks__
site/.lh-chrome
site/.lh-chrome-manual
site/.lh-profiles
site/.lh-temp
site/.swc
site/.agent
site/.claude
site/*.log
site/*.txt

# Local catalog mirror — production serves from R2 CDN
site/public/images
