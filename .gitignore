.next
.playwright-cli

# Local scratch files
.tmp-*.txt
site/nul

# Patch/reject artifacts
*.png
!/public/**/*.png
!site/tests/e2e/**/*-snapshots/*.png
features_diff.txt
.blackboxcli/

# Generated test/coverage artifacts under site/
.claude/
